					</odef>
				</tdef>
				<ldef id="line[]">
					<fdef id="line">SetDialogText</fdef>
				</ldef>
				<cdef id="wait_advance/wait_time">
					<fdef id="wait_advance">WaitForAdvanceText</fdef>
					<fdef id="wait_time">WaitForTime</fdef>
				</cdef>
			</ndef>
			<ndef id="Event">
				<fdef id="invoke">InvokeEvent</fdef>
			</ndef>
		</nodes>
	</schema>
