<file>
	<meta>
		<data id="title">Test</data>
		<data id="desc">A test program.</data>
		<data id="author">Corporation, Inc.</data>
		<data id="version">1.0.0</data>
		<check>b7bf65a2a60402a5e13672601a4fb496</check>
	</meta>
	<schema>
		<instrs>
			<idef id="SelectDialogWindow">
				<exec>Rusty.Cutscenes.SelectDialogWindowHandler</exec>
				<pdef id="name"/>
			</idef>
			<idef id="SetDialogWindowState">
				<exec>Rusty.Cutscenes.SetDialogWindowState</exec>
				<pdef id="state"/>
				<pdef id="time"/>
			</idef>
			<idef id="SetDialogText">
				<exec>Rusty.Cutscenes.SetDialogText</exec>
				<pdef id="speaker"/>
				<pdef id="mood"/>
				<pdef id="body"/>
			</idef>
			<idef id="InvokeEvent">
				<exec>Rusty.Cutscenes.InvokeEvent</exec>
				<pdef id="name"/>
			</idef>
			<idef id="WaitForAdvanceText">
				<exec>Rusty.Cutscenes.WaitForAdvanceText</exec>
			</idef>
			<idef id="WaitForTime">
				<exec>Rusty.Cutscenes.WaitForTime</exec>
				<pdef id="time"/>
			</idef>
		</instrs>
		<nodes>
			<ndef id="Dialog">
				<tdef id="select+state">
					<odef id="select?">
						<fdef type="SelectDialogWindow" id="select">
							<vadef/>
						</fdef>
					</odef>
					<odef id="set_state?">
						<fdef type="SetDialogWindowState" id="set_state">
							<vadef/>
							<vadef/>
						</fdef>
					</odef>
				</tdef>
				<ldef id="line[]">
					<fdef type="SetDialogText" id="line">
						<vadef/>
						<vadef/>
						<vadef/>
					</fdef>
				</ldef>
				<cdef id="wait_advance/wait_time">
					<fdef type="WaitForAdvanceText" id="wait_advance"/>
					<fdef type="WaitForTime" id="wait_time">
						<vadef/>
					</fdef>
				</cdef>
			</ndef>
			<ndef id="Event">
				<fdef type="InvokeEvent" id="invoke">
					<vadef/>
				</fdef>
			</ndef>
		</nodes>
	</schema>
	<graph>
		<elems>
			<memo id="m0">
				<x>0</x>
				<y>0</y>
				<member id="0"/>
				<text>This is a test program.</text>
				<color>00ff00</color>
			</memo>
			<frame id="f0">
				<x>50</x>
				<y>50</y>
				<width>100</width>
				<height>100</height>
				<text>Test Program</text>
				<color>ff0000</color>
			</frame>
			<node id="n1" type="Dialog">
				<x>100</x>
				<y>100</y>
				<member id="0"/>
				<start id="Start"/>
				<tuple>
					<option>
						<form>
							<arg>Main</arg>
						</form>
					</option>
					<option>
						<form>
							<arg>Open</arg>
							<arg>0.25</arg>
						</form>
					</option>
				</tuple>
				<list>
					<form>
						<arg>Johnny</arg>
						<arg>Happy</arg>
						<arg>Hello, world!</arg>
					</form>
					<form>
						<arg>Harry</arg>
						<arg>Happy</arg>
						<arg>Seeya!</arg>
					</form>
				</list>
				<choice select="wait_advance">
					<form/>
				</choice>
			</node>
			<node id="n1" type="Event">
				<x>300</x>
				<y>0</y>
				<start id="Start2"/>
				<form>
					<arg>Signal</arg>
				</form>
			</node>
			<joint id="j0">
				<x>200</x>
				<y>200</y>
			</joint>
		</elems>
		<edges>
			<edge id="e0">
				<from id="n0"/>
				<port>0</port>
				<to id="j0"/>
			</edge>
			<edge id="e1">
				<from id="j0"/>
				<port>0</port>
				<to id="n1"/>
			</edge>
			<edge id="e2">
				<from id="n1"/>
				<port>0</port>
				<to id="n0"/>
			</edge>
		</edges>
	</graph>
</file>
