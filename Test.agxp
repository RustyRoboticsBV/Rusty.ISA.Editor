	<meta id="version" value="1.0.0"/>
	<check>b7bf65a2a60402a5e13672601a4fb496</check>
	
	<!-- Schema -->
	<idef id="i1" exec="Handler1">
		<pdef id="p1"/>
	</idef>
	<idef id="i2" exec="Handler2">
		<pdef id="p2"/>
		<pdef id="p3"/>
	</idef>
	<idef id="i3" exec="Handler3">
		<pdef id="p4"/>
		<pdef id="p5"/>
		<pdef id="p6"/>
	</idef>
	<ndef id="n1">
		<ldef id="l1">
			<tdef id="t1">
				<cdef id="c1">
					<odef id="o1">
						<fdef type="i1" id="f1">
							<vadef id="va1" type="p1"/>
						</fdef>
					</odef>
					<odef id="o2">
						<fdef type="i2" id="f2">
							<vadef id="va2" type="p2"/>
							<oadef id="oa3" type="p3" nodefault="false"/>
						</fdef>
					</odef>
					<odef id="o3">
						<fdef type="i3" id="f3">
							<oadef id="oa4" type="p4" nodefault="false"/>
							<vadef id="va5" type="p5"/>
							<oadef id="oa6" type="p6" nodefault="true"/>
						</fdef>
					</odef>
				</cdef>
			</tdef>
		</ldef>
	</ndef>
	
	<!-- Graph -->
	<memo id="m1" x="0" y="0" member="f1" text="This is a test program." color="00ff00"/>
	<frame id="f1" x="50" y="50" width="100" height="100" text="Test Program" color="ff0000"/>
	<node id="n1" type="n1" x="100" y="100" member="f1" start="Start">
		<list type="l1">
			<tuple type="t1">
				<choice type="c1">
					<option type="o3">
						<form type="f3">
							<out type="oa4"/>
							<arg type="va5" value="10"/>
							<out type="oa6"/>
						</form>
					</option>
				</choice>
			</tuple>
			<tuple type="t1">
				<choice type="c1">
					<option type="o1"/>
				</choice>
			</tuple>
